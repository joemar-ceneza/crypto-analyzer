# crypto-analyzer — environment variables
# Copy this file to .env and fill in real values if/when needed.
#
# Public market data from Binance needs NO API key.

# --- Signal alerts (main.py --alerts) ---
# Telegram: create a bot with @BotFather to get the token, then message
# @userinfobot to get your numeric chat id. See README "Telegram alerts".
TELEGRAM_BOT_TOKEN=your_bot_token_here
# One or more recipients, comma-separated. Each can be a personal chat id,
# a group id, or a channel (@channelname or its -100... id). Examples:
#   TELEGRAM_CHAT_ID=123456789
#   TELEGRAM_CHAT_ID=123456789,987654321
#   TELEGRAM_CHAT_ID=@my_signals_channel
TELEGRAM_CHAT_ID=your_chat_id_here

# --- Optional / future ---
# BINANCE_API_KEY=your_api_key_here
# BINANCE_API_SECRET=your_api_secret_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
