# crypto_analyzer — environment variables
# Copy this file to .env and fill in real values if/when needed.
#
# Public market data from Binance needs NO API key.
# These are only required if you later enable private endpoints or the
# Claude-powered AI layer (currently rule-based, so nothing is required).

# BINANCE_API_KEY=your_api_key_here
# BINANCE_API_SECRET=your_api_secret_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
